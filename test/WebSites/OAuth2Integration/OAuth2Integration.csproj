  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Duende.IdentityServer" VersionOverride="7.4.7" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net8.0'">
    <PackageReference Include="Microsoft.AspNetCore.Authentication.JwtBearer" VersionOverride="8.0.26" />
